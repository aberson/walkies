# Normalize text files to LF in the repository to avoid CRLF churn in this
# Windows-primary workspace (prettier/eslint expect LF; see CLAUDE.md shell rules).
* text=auto eol=lf

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
